# BasicUpdateFlow

main: kit: flow: BasicUpdateFlow:
{
  entity: "update",
  kind: "basic",
  name: "BasicUpdateFlow",
  step: [
    {
      input: {
        ref: "update_ref01",
        srcdatavar: "update_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-update_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicUpdateFlow"
}